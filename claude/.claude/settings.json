{
  "autoUpdatesChannel": "stable",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"$HOME/.claude/hooks/headsdown-prompt.sh\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"$HOME/.claude/hooks/nvim-refresh.sh\"'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'rm -f \"$HOME/.claude/temp/headsdown.json\"'"
          }
        ]
      }
    ]
  }
}
