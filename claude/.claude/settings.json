{
  "model": "opus",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"$HOME/.claude/hooks/session-prompt.sh\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"$HOME/.claude/hooks/nvim-refresh.sh\"'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'rm -f \"$HOME/.claude/temp/headsdown.json\"; PID_FILE=\"$HOME/.claude/temp/session-timer.pid\"; if [ -f \"$PID_FILE\" ]; then kill $(cat \"$PID_FILE\") 2>/dev/null; rm -f \"$PID_FILE\" \"$HOME/.claude/temp/session.json\" \"$HOME/.claude/temp/session-timer.sh\"; fi'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "caveman@caveman": true,
    "obsidian@obsidian-skills": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    }
  },
  "autoUpdatesChannel": "stable",
  "statusLine": {
    "type": "command",
    "command": "bash \"/Users/carlos/Code/github.com/caaldrid/.dotfiles/claude/.claude/plugins/cache/caveman/caveman/80a317e4725f/hooks/caveman-statusline.sh\""
  }
}
